generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RagStatus {
  RED
  AMBER
  GREEN
}

model PortfolioUpdate {
  id                      String    @id @default(cuid())
  portfolioName           String
  reportingMonth          DateTime  @db.Date
  cashPositionNgn         Decimal   @db.Decimal(18, 2)
  ragStatus               RagStatus
  primaryExecutionBlocker String
  kpis                    Kpi[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([portfolioName, reportingMonth])
}

model Kpi {
  id                String          @id @default(cuid())
  name              String
  targetValue       Decimal         @db.Decimal(14, 2)
  actualValue       Decimal         @db.Decimal(14, 2)
  portfolioUpdateId String
  portfolioUpdate   PortfolioUpdate @relation(fields: [portfolioUpdateId], references: [id], onDelete: Cascade)

  @@unique([portfolioUpdateId, name])
}
